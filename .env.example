# DATABASE
# DATABASE_URL → Neon pooler endpoint (PgBouncer, used at runtime by Prisma)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=30"
# DIRECT_URL  → Neon direct endpoint (used only for migrations: prisma migrate / db push)
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# FRONTEND
FRONTEND_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# BACKEND
NODE_ENV="development"
PORT="3001"
JWT_ACCESS_SECRET="jwt-access-secret-key"
JWT_REFRESH_SECRET="jwt-refresh-secret-key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/callback/google"

# EMAIL (SENDGRID)
# Obtener la API Key desde: https://app.sendgrid.com/settings/api_keys
# Generar una nueva clave con permisos de "Mail Send"
SENDGRID_API_KEY="SG.your-sendgrid-api-key-here"
# Email de origen (debe ser verificado en SendGrid)
EMAIL_FROM="noreply@example.com"

# SKYDROPX SHIPPING (carrier principal — agrega FedEx, DHL, Estafeta y más)
# Credenciales: app.skydropx.com → Integraciones → API
# Webhook URL: POST /envios/webhook/skydropx
SKYDROPX_ENV="sandbox"
SKYDROPX_CLIENT_ID="your-skydropx-client-id"
SKYDROPX_CLIENT_SECRET="your-skydropx-client-secret"
SKYDROPX_WEBHOOK_SECRET="your-skydropx-webhook-secret"
SKYDROPX_SHIPPER_NAME="Productor Mezcal"
SKYDROPX_SHIPPER_PHONE="9511234567"
SKYDROPX_SHIPPER_EMAIL="envios@tudominio.mx"
SKYDROPX_SHIPPER_STREET="Calle Principal 1"
SKYDROPX_SHIPPER_POSTAL_CODE="68000"
SKYDROPX_SHIPPER_CITY="Oaxaca de Juárez"
SKYDROPX_SHIPPER_STATE="Oaxaca"
SKYDROPX_SHIPPER_COLONIA="Centro"


# STRIPE (Payments + Connect Express)
# Dashboard: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_..., pk_test_...) in development.
STRIPE_SECRET_KEY="sk_test_your_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
# Webhook signing secret from `stripe listen` or Dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
# Connect platform client_id (Settings → Connect → OAuth settings).
STRIPE_CONNECT_CLIENT_ID="ca_your_connect_client_id"
# Frontend-exposed publishable key (must mirror STRIPE_PUBLISHABLE_KEY).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# CURRENCY / LOCALE
# Default currency when shipping to USA (ISO 4217).
DEFAULT_CURRENCY_USA="USD"
# Optional: GeoIP key for auto-detecting buyer country (ipinfo, MaxMind, etc.).
GEOIP_PROVIDER_KEY=""

# EXCHANGE RATES (tasas-cambio-sync.service.ts — cron cada hora)
# Obtener API key GRATIS en: https://app.exchangerate-api.com/sign-up
# Sin esta variable el cron falla silenciosamente y el checkout usa tasas desactualizadas.
EXCHANGERATE_API_KEY="your-exchangerate-api-key"
# Edad máxima (horas) de una tasa antes de considerarla obsoleta y BLOQUEAR el pago
# internacional (default 24). Ver validarTasaCambioVigente en pagos.service.ts.
FX_MAX_AGE_HORAS="24"

# UPLOADS (imágenes de productos en local — docker-compose.prod.yml)
# Ruta PERSISTENTE del host donde se guardan las imágenes (bind mount). En producción
# usar una ruta con respaldo, p.ej. /var/marketplace/uploads. Respaldar con
# scripts/backup-uploads.sh en un cron diario.
UPLOADS_HOST_PATH="./data/uploads"
# Destino y retención de los backups de uploads (scripts/backup-uploads.sh).
BACKUP_DEST_DIR="./data/backups"
BACKUP_KEEP="14"
