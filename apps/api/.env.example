# API (NestJS) — apps/api/.env.example
# main.ts loads apps/api/.env first, then root .env (si existe).
# Vars definidas aquí tienen prioridad sobre root .env.

# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
# DATABASE_URL → Neon pooler endpoint (PgBouncer, runtime de Prisma)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=30"
# DIRECT_URL  → Neon direct endpoint (solo para migrations: prisma migrate / db push)
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# ──────────────────────────────────────────────
# RUNTIME
# ──────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
# Opcional. Por defecto se usa apps/api/uploads; admite ruta absoluta o relativa al cwd.
UPLOADS_ROOT=""
# Orígenes permitidos para CORS (separados por coma). Primer valor es el fallback en dev.
CORS_ORIGINS="http://localhost:3000,https://marketplace-mezcal.vercel.app"

# ──────────────────────────────────────────────
# JWT & AUTH
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET="jwt-access-secret-key"
JWT_REFRESH_SECRET="jwt-refresh-secret-key"
PASSWORD_RESET_SECRET="password-reset-secret-key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
# Opcional. Default: 30m
PASSWORD_RESET_EXPIRES_IN="30m"
# NextAuth secret (compartido con web, requerido en produccion)
NEXTAUTH_SECRET="your-nextauth-secret"

# ──────────────────────────────────────────────
# GOOGLE OAUTH
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/callback/google"

# ──────────────────────────────────────────────
# EMAIL
# ──────────────────────────────────────────────
# Canal principal: SendGrid
SENDGRID_API_KEY=""
EMAIL_FROM=""
# Fallback SMTP (Gmail) — opcional, usado si SendGrid no esta configurado
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Destinatario para notificaciones administrativas (opcional)
ADMIN_EMAIL=""

# ──────────────────────────────────────────────
# SKYDROPX SHIPPING
# ──────────────────────────────────────────────
SKYDROPX_ENV="sandbox"
SKYDROPX_CLIENT_ID="your-skydropx-client-id"
SKYDROPX_CLIENT_SECRET="your-skydropx-client-secret"
SKYDROPX_WEBHOOK_SECRET="your-skydropx-webhook-secret"
# Datos del remitente
SKYDROPX_SHIPPER_NAME="Productor Mezcal"
SKYDROPX_SHIPPER_PHONE="9511234567"
SKYDROPX_SHIPPER_EMAIL="envios@tudominio.mx"
SKYDROPX_SHIPPER_STREET="Calle Principal 1"
SKYDROPX_SHIPPER_POSTAL_CODE="68000"
SKYDROPX_SHIPPER_CITY="Oaxaca de Juarez"
SKYDROPX_SHIPPER_STATE="Oaxaca"
SKYDROPX_SHIPPER_COLONIA="Centro"
# Codigo armonizado para mezcal
SKYDROPX_HS_CODE_DEFAULT="2208.907200"
# Parametros de proteccion de envios (opcional, default: 0)
SKYDROPX_PROTECTION_PCT="2.5"
SKYDROPX_PROTECTION_FIXED_MXN="10"
# Parametros aduanales para envios internacionales (opcional)
SKYDROPX_PRODUCT_TYPE_CODE=""
SKYDROPX_PRODUCT_TYPE_NAME=""
SKYDROPX_CUSTOMS_PAYER=""
SKYDROPX_SHIPMENT_PURPOSE=""

# ──────────────────────────────────────────────
# PAYPAL
# ──────────────────────────────────────────────
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"

# ──────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_your_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_CONNECT_CLIENT_ID="ca_your_connect_client_id"

# ──────────────────────────────────────────────
# MONEDA Y LOCALIZACION
# ──────────────────────────────────────────────
DEFAULT_CURRENCY_USA="USD"
GEOIP_PROVIDER_KEY=""

# ──────────────────────────────────────────────
# TASAS DE CAMBIO
# ──────────────────────────────────────────────
EXCHANGERATE_API_KEY="your-exchangerate-api-key"
# Opcional. Default: 1 (hora)
FX_MAX_AGE_HORAS="24"
# Tasas de respaldo estaticas (opcional). Formato: FX_FALLBACK_{FROM}_{TO}
# Ej: FX_FALLBACK_MXN_USD="0.050", FX_FALLBACK_USD_MXN="20.0"
FX_FALLBACK_MXN_USD=""
FX_FALLBACK_USD_MXN=""

# ──────────────────────────────────────────────
# CIFRADO
# ──────────────────────────────────────────────
# Generar con: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
# Debe ser 64 caracteres hex. No cambiar o se pierden datos cifrados existentes.
ENCRYPTION_KEY="your-64-hex-char-encryption-key"

# ──────────────────────────────────────────────
# MONITOREO (opcional)
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# FEATURE FLAGS (opcional)
# ──────────────────────────────────────────────
# Permite ejecutar seed de datos demo en produccion (solo desarrollo)
ALLOW_DEMO_SEED="false"
