# API (NestJS) — apps/api/.env.example
# main.ts loads apps/api/.env first, then root .env. Vars defined here win.

# DATABASE
DATABASE_URL="postgresql://user:password@host:5432/database_name"

# RUNTIME
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"

# JWT
JWT_ACCESS_SECRET="jwt-access-secret-key"
JWT_REFRESH_SECRET="jwt-refresh-secret-key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/auth/callback/google"

# EMAIL (SENDGRID)
SENDGRID_API_KEY=""
EMAIL_FROM=""

# FEDEX SHIPPING
# Developer portal: https://developer.fedex.com
FEDEX_ENV="sandbox"
FEDEX_CLIENT_ID="your-fedex-client-id"
FEDEX_CLIENT_SECRET="your-fedex-client-secret"
FEDEX_ACCOUNT_NUMBER="your-fedex-account-number"
FEDEX_SHIPPER_COUNTRY_CODE="MX"
FEDEX_SHIPPER_POSTAL_CODE="68000"
FEDEX_SHIPPER_CITY="Oaxaca de Juárez"
FEDEX_WEBHOOK_SECRET="your-fedex-webhook-secret"

# STRIPE (server-side only — keep secret_key out of the web app)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
# Webhook signing secret. Locally use `stripe listen --forward-to localhost:3001/pagos/stripe/webhook`.
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
# Connect platform client_id (Settings → Connect → OAuth settings).
STRIPE_CONNECT_CLIENT_ID="ca_your_connect_client_id"

# CURRENCY
DEFAULT_CURRENCY_USA="USD"

# Optional: GeoIP key for auto-detecting buyer country (ipinfo, MaxMind, etc.).
GEOIP_PROVIDER_KEY=""
