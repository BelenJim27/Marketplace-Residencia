# Web (Next.js) — apps/web/.env.example
# Only NEXT_PUBLIC_* vars are exposed to the browser. Never put secrets here.

NODE_ENV="development"

# API
NEXT_PUBLIC_API_URL="http://localhost:3001"

# AUTH (NextAuth — Google OAuth flow)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# STRIPE (publishable key only — safe to ship to the client)
# Must match STRIPE_PUBLISHABLE_KEY on the API side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
