# Web (Next.js) — apps/web/.env.example
# Solo NEXT_PUBLIC_* se exponen al navegador. Nunca pongas secrets aqui.
# Next.js carga .env.local > .env.production > .env > .env.example

NODE_ENV="development"

# ──────────────────────────────────────────────
# API (backend)
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# URL de tracking SkydropX para clientes
NEXT_PUBLIC_SKYDROPX_TRACKING_URL="https://sb-tracking.skydropx.com/es-MX/page/Mezcanea"

# URL canónica del sitio (usada en sitemap, robots, JSON-LD, meta tags)
# Debe coincidir con el deployment (ej: https://marketplace-mezcal.vercel.app)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────────────────────────────────────
# AUTH (NextAuth — Google OAuth)
# ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# ──────────────────────────────────────────────
# PAGOS (solo claves públicas — seguras para el cliente)
# ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"

# ──────────────────────────────────────────────
# GEMINI AI — Chat Widget
# ──────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY="AQ..."

# ──────────────────────────────────────────────
# SENTRY (monitoreo de errores) — opcional
# ──────────────────────────────────────────────
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ──────────────────────────────────────────────
# CLOUDINARY (subida de imágenes) — preparado, sin implementar
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
